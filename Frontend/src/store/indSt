import { create } from 'zustand';
import { persist } from 'zustand/middleware';

export const useAuthStore = create(persist(
  (set) => ({
    user: null, token: null, refreshToken: null,
    selectedCompany: null, companies: [],

    setAuth: (user, token, refreshToken, companies) => {
      localStorage.setItem('smartca_token', token);
      localStorage.setItem('smartca_refresh', refreshToken);
      set({ user, token, refreshToken, companies,
            selectedCompany: companies?.[0] || null });
      if (companies?.[0]) localStorage.setItem('smartca_company', companies[0].id);
    },

    setCompany: (company) => {
      localStorage.setItem('smartca_company', company.id);
      set({ selectedCompany: company });
    },

    logout: () => {
      localStorage.removeItem('smartca_token');
      localStorage.removeItem('smartca_refresh');
      localStorage.removeItem('smartca_company');
      set({ user: null, token: null, refreshToken: null, selectedCompany: null });
    },
  }),
  { name: 'smartca-auth', partialize: s => ({ user: s.user, token: s.token, refreshToken: s.refreshToken, selectedCompany: s.selectedCompany }) }
));
